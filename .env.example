# Copy to .env and adjust as needed (optional — defaults work for local dev)

# Infrastructure host ports
MYSQL_HOST_PORT=3307
REDIS_HOST_PORT=6380
RABBITMQ_HOST_PORT=5673
RABBITMQ_MANAGEMENT_HOST_PORT=15673
APP_HOST_PORT=8080

# Backend (when running outside Docker)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=fsd_core
DB_USERNAME=root
DB_PASSWORD=root
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5673
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
SERVER_PORT=8080

# Fleet energy (optional overrides)
# FSD_FLEET_ENERGY_LOW_SOC_THRESHOLD=25
# FSD_FLEET_ENERGY_MIN_ASSIGNABLE_SOC=30
# FSD_FLEET_ENERGY_FULL_SOC=100
