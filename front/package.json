{
  "name": "dispatchflow-web",
  "description": "DispatchFlow admin console and vehicle monitoring UI",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:analyze": "vue-tsc --noEmit && vite build --mode analyze",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,less,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,less,json}\"",
    "perf:lighthouse": "node scripts/perf/lighthouse-routes.mjs",
    "perf:nav": "playwright test scripts/perf",
    "test:e2e": "playwright test scripts/e2e",
    "perf:all": "npm run build && npm run perf:lighthouse && npm run perf:nav"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@ant-design/icons-vue": "^7.0.1",
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@fontsource/geist": "^5.2.9",
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "leaflet": "^1.9.4",
    "pinia": "^2.3.0",
    "vite-plugin-pwa": "^0.21.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.52.0",
    "@types/leaflet": "^1.9.21",
    "@vitejs/plugin-vue": "^5.2.3",
    "chrome-launcher": "^1.2.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-vue": "^9.32.0",
    "less": "^4.2.1",
    "lighthouse": "^12.6.0",
    "prettier": "^3.4.2",
    "puppeteer-core": "^24.8.2",
    "rollup-plugin-visualizer": "^5.14.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.3.5",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.2.0"
  }
}
