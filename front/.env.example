# Optional local overrides (copy to .env.local — do NOT commit real keys)

# VITE_API_PROXY=http://localhost:8080
# VITE_ADMIN_AUTH_ENABLED=false

# --- V3 高德地图（Web JS API 2.0）---
# 控制台：https://console.amap.com/dev/key/app
# 服务平台选「Web端(JS API)」，并配置安全密钥 + 域名白名单
VITE_MAP_PROVIDER=AMAP
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=
# 默认地图中心：南通海门叠石桥国际家纺城片区 [经度,纬度] GCJ-02
VITE_AMAP_DEFAULT_CENTER=121.080354,31.961977
VITE_AMAP_DEFAULT_ZOOM=15

# --- 生产部署（二选一）---
# 1) 构建时注入：复制本文件为 front/.env.production，填 Key 后 npm run build
# 2) 部署后热更新：编辑 dist/runtime-config.js（参考 public/runtime-config.example.js）

# 移动下单（POST /admin/park/orders 请求头 X-Mobile-Api-Key）
# 演示 Key 见 Flyway V24；也可在系统 → 集成管理 创建
VITE_MOBILE_API_KEY=ZJF-MOBILE-DEMO-2026
